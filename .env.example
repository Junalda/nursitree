# Supabase credentials used by the contact form (src/lib/supabase.ts).
#
# The "anon" key is a public, browser-safe key protected by Row Level Security
# and is intended to be shipped to the client. It is kept in env vars only to
# avoid committing it to the repository. Never put a Supabase *service role*
# key (or any true secret) in a VITE_ variable — those are bundled into the
# frontend and would be publicly exposed.
#
# Local setup:  cp .env.example .env  then fill in the values below.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
